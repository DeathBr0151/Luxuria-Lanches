rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - description: string (optional)
    //   - price: number (required)
    //   - category: string (required, enum: ['lanches', 'combos', 'bebidas'])
    //   - imageUrl: string (optional)
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, enum: ['admin', 'customer'])
    //
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required)
    //   - items: list (required)
    //   - total: number (required)
    //   - status: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: settings
    // Document ID: info (and others)
    // Fields:
    //   - openingHours: map (required)
    //   - address: string (required)
    //   - phone: string (required)
    //   - whatsappNumber: string (required)
    //   - logoUrl: string (optional)
    //
    // Collection: test
    // Document ID: connection
    // Fields: any
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "pinheiro0151@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidProduct(data) {
      return data.keys().hasOnly(['name', 'description', 'price', 'category', 'imageUrl', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category in ['lanches', 'combos', 'bebidas'] &&
             (!('description' in data) || (data.description is string && data.description.size() < 500)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() < 1000));
    }

    function isValidUser(data) {
      return data.uid is string && data.email is string &&
             data.role in ['admin', 'customer'];
    }

    function isValidOrder(data) {
      return data.userId is string && data.items is list &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'preparing', 'delivering', 'completed', 'cancelled'];
    }

    function isValidOrderUpdate(newData, oldData) {
      // User can only cancel their own pending order
      return newData.diff(oldData).affectedKeys().hasOnly(['status']) &&
             newData.status == 'cancelled' &&
             oldData.status == 'pending';
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['openingHours', 'address', 'phone', 'whatsappNumber']) &&
             data.openingHours is map &&
             data.openingHours.keys().hasAll(['monThu', 'friSat', 'sun']) &&
             data.address is string && data.address.size() > 0 && data.address.size() < 500 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 50 &&
             data.whatsappNumber is string && data.whatsappNumber.size() > 0 && data.whatsappNumber.size() < 50;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true; // Publicly readable menu
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'customer';
      allow update: if isAuthenticated() && (
        (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) ||
        (isAdmin() && isValidUser(request.resource.data))
      );
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidOrder(request.resource.data);
      allow update: if isAdmin() || (isOwner(resource.data.userId) && isValidOrderUpdate(request.resource.data, resource.data));
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // Business info should be public
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /test/{testId} {
      allow read: if true; // Connection test
    }
  }
}
