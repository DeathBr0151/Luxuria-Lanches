{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A menu item (snack, combo, or drink)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["lanches", "combos", "bebidas"] },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "price", "category"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] }
      },
      "required": ["uid", "email"]
    },
    "Order": {
      "title": "Order",
      "description": "A record of a customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Business configuration and information",
      "type": "object",
      "properties": {
        "openingHours": { "type": "object" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "logoUrl": { "type": "string" }
      },
      "required": ["openingHours", "address", "phone", "whatsappNumber"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Menu items"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Order history"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Business settings"
    },
    "/test/{testId}": {
      "schema": "object",
      "description": "Connection test"
    }
  }
}
